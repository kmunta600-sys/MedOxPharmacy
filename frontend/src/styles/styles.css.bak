    border-radius: 2px;
}

.dropdown-menu::-webkit-scrollbar-thumb:hover {
    background: rgba(214, 158, 46, 0.3);
}

/* Dropdown item with delete button */
.dropdown-item {
    display: flex !important;
    justify-content: space-between !important;
    align-items: center !important;
    padding: 6px 12px !important;
}

.dropdown-item-text {
    flex: 1;
    color: rgba(255,255,255,0.7);
}

.dropdown-delete-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.15);
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 4px;
    transition: all 0.2s ease;
    display: flex;
    align-items: center;
    opacity: 0;
}

.dropdown-item:hover .dropdown-delete-btn {
    opacity: 1;
}

.dropdown-delete-btn:hover {
    color: #EF4444;
    background: rgba(239, 68, 68, 0.08);
}

.dropdown-delete-btn svg {
    width: 14px;
    height: 14px;
}

/* Show delete button on hover */
.dropdown-item:hover {
    background: rgba(255,255,255,0.03);
}

.dropdown-item:hover .dropdown-item-text {
    color: #FFFFFF;
}

/* ============================================================
   RECEIVE STOCK PAGE
   ============================================================ */

.receive-stock-wrapper {
    min-height: 100vh;
    height: 100vh;
    background: #0A0F1E;
    color: #FFFFFF;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* Header */
.receive-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 24px;
    background: rgba(10, 15, 30, 0.95);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
    backdrop-filter: blur(10px);
    z-index: 10;
}

.header-left {
    display: flex;
    align-items: center;
    gap: 12px;
}

.header-icon {
    font-size: 24px;
}

.header-brand {
    font-size: 18px;
    font-weight: 700;
    color: #FFFFFF;
}

.header-badge {
    background: rgba(214, 158, 46, 0.12);
    color: #D69E2E;
    padding: 2px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    border: 1px solid rgba(214, 158, 46, 0.1);
}

.header-right {
    display: flex;
    gap: 10px;
}

.btn-back, .btn-logout {
    padding: 6px 16px;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 500;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-back {
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.5);
    border: 1px solid rgba(255,255,255,0.06);
}

.btn-back:hover {
    background: rgba(255,255,255,0.08);
    color: #FFFFFF;
}

.btn-logout {
    background: rgba(255,255,255,0.04);
    color: rgba(255,255,255,0.4);
    border: 1px solid rgba(255,255,255,0.06);
}

.btn-logout:hover {
    background: rgba(239, 68, 68, 0.1);
    color: #EF4444;
    border-color: rgba(239, 68, 68, 0.2);
}

/* Content */
.receive-content {
    flex: 1;
    padding: 16px 24px 20px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(214,158,46,0.2) transparent;
}

.receive-content::-webkit-scrollbar {
    width: 6px;
}

.receive-content::-webkit-scrollbar-track {
    background: transparent;
}

.receive-content::-webkit-scrollbar-thumb {
    background: rgba(214,158,46,0.15);
    border-radius: 3px;
}

.receive-content::-webkit-scrollbar-thumb:hover {
    background: rgba(214,158,46,0.3);
}

.receive-page-header {
    margin-bottom: 16px;
}

.receive-page-header h1 {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    color: #FFFFFF;
}

.receive-page-header p {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    margin: 2px 0 0 0;
}

/* Alert */
.alert-success {
    background: rgba(16, 185, 129, 0.06);
    border: 1px solid rgba(16, 185, 129, 0.08);
    color: #10B981;
    padding: 8px 16px;
    border-radius: 8px;
    margin-bottom: 12px;
    font-size: 13px;
}

.alert-error {
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.08);
    color: #EF4444;
    padding: 8px 16px;
    border-radius: 8px;
    margin-bottom: 12px;
    font-size: 13px;
}

/* Grid */
.receive-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 20px;
    height: calc(100vh - 200px);
}

.receive-left {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.receive-right {
    display: flex;
    flex-direction: column;
    min-height: 0;
}

/* Cards */
.receive-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 16px 18px;
}

.card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}

.card-header h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    color: rgba(255,255,255,0.6);
}

.card-icon {
    font-size: 16px;
}

.card-badge {
    font-size: 10px;
    color: rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.04);
    padding: 1px 10px;
    border-radius: 12px;
}

.card-title {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: #FFFFFF;
}

/* Batch Defaults */
.batch-defaults-row {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr auto;
    gap: 10px;
}

.btn-apply-defaults {
    padding: 6px 16px;
    background: rgba(214, 158, 46, 0.08);
    border: 1px solid rgba(214, 158, 46, 0.06);
    border-radius: 6px;
    color: #D69E2E;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    white-space: nowrap;
}

.btn-apply-defaults:hover:not(:disabled) {
    background: rgba(214, 158, 46, 0.15);
}

.btn-apply-defaults:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

/* Search */
.search-wrapper {
    position: relative;
    margin-bottom: 10px;
}

.search-input {
    width: 100%;
    padding: 8px 14px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    color: #FFFFFF;
    font-size: 13px;
    outline: none;
    transition: all 0.3s ease;
    font-family: inherit;
    height: 38px;
}

.search-input:focus {
    border-color: rgba(214, 158, 46, 0.3);
    box-shadow: 0 0 0 3px rgba(214, 158, 46, 0.05);
}

.search-input::placeholder {
    color: rgba(255,255,255,0.15);
}

.search-dropdown {
    position: absolute;
    top: 100%;
    left: 0;
    right: 0;
    background: #1A2332;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    margin-top: 4px;
    max-height: 180px;
    overflow-y: auto;
    z-index: 100;
    box-shadow: 0 8px 30px rgba(0,0,0,0.4);
}

.search-dropdown-item {
    padding: 8px 14px;
    cursor: pointer;
    border-bottom: 1px solid rgba(255,255,255,0.03);
    transition: all 0.2s ease;
    display: flex;
    justify-content: space-between;
    align-items: center;
}

.search-dropdown-item:hover {
    background: rgba(214, 158, 46, 0.05);
}

.dropdown-name {
    color: #FFFFFF;
    font-size: 13px;
    font-weight: 500;
}

.dropdown-detail {
    color: rgba(255,255,255,0.3);
    font-size: 11px;
}

/* Selected Product */
.selected-product {
    background: rgba(214, 158, 46, 0.04);
    border: 1px solid rgba(214, 158, 46, 0.06);
    border-radius: 8px;
    padding: 8px 14px;
    margin-bottom: 12px;
    display: flex;
    flex-wrap: wrap;
    gap: 16px;
}

.selected-info {
    display: flex;
    align-items: center;
    gap: 4px;
    font-size: 13px;
}

.selected-label {
    color: rgba(255,255,255,0.3);
}

.selected-value {
    color: #FFFFFF;
    font-weight: 500;
}

.selected-stock {
    color: #D69E2E;
    font-weight: 600;
}

.selected-code {
    color: rgba(255,255,255,0.3);
}

/* Form */
.form-row-3 {
    display: grid;
    grid-template-columns: 1fr 1fr 1fr;
    gap: 10px;
    margin-bottom: 10px;
}

.form-group {
    display: flex;
    flex-direction: column;
    gap: 3px;
}

.form-label {
    font-size: 11px;
    font-weight: 500;
    color: rgba(255,255,255,0.3);
    text-transform: uppercase;
    letter-spacing: 0.3px;
}

.form-input {
    padding: 6px 10px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 6px;
    color: #FFFFFF;
    font-size: 13px;
    font-family: inherit;
    outline: none;
    transition: all 0.3s ease;
    height: 34px;
    width: 100%;
    box-sizing: border-box;
}

.form-input:focus {
    border-color: rgba(214, 158, 46, 0.3);
    box-shadow: 0 0 0 3px rgba(214, 158, 46, 0.05);
}

.form-input:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

.form-input::placeholder {
    color: rgba(255,255,255,0.1);
}

.required-dot {
    color: #EF4444;
}

/* Buttons */
.btn-add-to-list {
    width: 100%;
    padding: 8px 16px;
    background: linear-gradient(135deg, #D69E2E, #ECC94B);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-add-to-list:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(214, 158, 46, 0.25);
}

.btn-add-to-list:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Items Card */
.items-card {
    flex: 1;
    display: flex;
    flex-direction: column;
    min-height: 0;
}

.items-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-bottom: 10px;
    padding-bottom: 8px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
}

.items-header h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    color: #FFFFFF;
    display: flex;
    align-items: center;
    gap: 8px;
}

.items-count {
    background: rgba(214, 158, 46, 0.1);
    color: #D69E2E;
    padding: 0px 10px;
    border-radius: 12px;
    font-size: 12px;
}

.btn-clear-all {
    padding: 4px 12px;
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.08);
    color: #EF4444;
    border-radius: 6px;
    font-size: 11px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 4px;
}

.btn-clear-all:hover {
    background: rgba(239, 68, 68, 0.12);
}

/* Table */
.items-table-wrapper {
    flex: 1;
    overflow-y: auto;
    margin: 0 -4px;
    padding: 0 4px;
}

.items-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 12px;
}

.items-table thead {
    position: sticky;
    top: 0;
    z-index: 10;
}

.items-table th {
    text-align: left;
    padding: 6px 8px;
    background: rgba(10, 15, 30, 0.95);
    color: rgba(255,255,255,0.3);
    font-weight: 600;
    font-size: 10px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
    border-bottom: 1px solid rgba(255,255,255,0.04);
}

.items-table td {
    padding: 4px 8px;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    color: rgba(255,255,255,0.7);
    vertical-align: middle;
}

.items-table tr:hover td {
    background: rgba(255,255,255,0.02);
}

.item-name {
    color: #FFFFFF;
    font-weight: 500;
}

.qty-input {
    width: 50px;
    padding: 2px 4px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 4px;
    color: #FFFFFF;
    font-size: 12px;
    text-align: center;
    font-family: inherit;
    outline: none;
    height: 26px;
}

.qty-input:focus {
    border-color: rgba(214, 158, 46, 0.3);
}

.inline-input {
    width: 100%;
    padding: 2px 4px;
    background: transparent;
    border: none;
    color: rgba(255,255,255,0.5);
    font-size: 11px;
    font-family: inherit;
    outline: none;
}

.inline-input:focus {
    background: rgba(255,255,255,0.04);
    border-radius: 4px;
    color: #FFFFFF;
}

.inline-input::placeholder {
    color: rgba(255,255,255,0.1);
}

.btn-remove-item {
    background: none;
    border: none;
    color: rgba(255,255,255,0.15);
    cursor: pointer;
    padding: 2px 4px;
    border-radius: 4px;
    transition: all 0.2s ease;
}

.btn-remove-item:hover {
    color: #EF4444;
    background: rgba(239, 68, 68, 0.08);
}

/* Summary */
.items-summary {
    display: flex;
    justify-content: space-between;
    align-items: center;
    margin-top: 10px;
    padding-top: 10px;
    border-top: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
}

.summary-left {
    display: flex;
    gap: 20px;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
}

.summary-left strong {
    color: #FFFFFF;
}

.btn-receive-all {
    padding: 6px 20px;
    background: linear-gradient(135deg, #10B981, #059669);
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-receive-all:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.25);
}

.btn-receive-all:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.spinner-small {
    width: 14px;
    height: 14px;
    border: 2px solid rgba(255,255,255,0.2);
    border-top-color: #FFFFFF;
    border-radius: 50%;
    animation: spin 0.6s linear infinite;
}

/* Empty State */
.empty-state {
    flex: 1;
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    color: rgba(255,255,255,0.2);
    padding: 30px 0;
}

.empty-icon {
    font-size: 48px;
    opacity: 0.15;
    margin-bottom: 8px;
}

.empty-state p {
    font-size: 16px;
    font-weight: 500;
    color: rgba(255,255,255,0.3);
    margin: 0;
}

.empty-state span {
    font-size: 13px;
    opacity: 0.4;
}

/* Responsive */
@media (max-width: 1024px) {
    .receive-grid {
        grid-template-columns: 1fr;
        height: auto;
    }
    
    .receive-right {
        min-height: 300px;
    }
    
    .batch-defaults-row {
        grid-template-columns: 1fr 1fr;
    }
}

@media (max-width: 768px) {
    .receive-header {
        padding: 8px 16px;
        flex-wrap: wrap;
        gap: 8px;
    }
    
    .receive-content {
        padding: 12px 14px 16px;
    }
    
    .form-row-3 {
        grid-template-columns: 1fr;
        gap: 6px;
    }
    
    .batch-defaults-row {
        grid-template-columns: 1fr;
    }
    
    .items-table-wrapper {
        overflow-x: auto;
    }
    
    .items-table {
        font-size: 11px;
        min-width: 600px;
    }
    
    .items-summary {
        flex-direction: column;
        gap: 8px;
        align-items: stretch;
    }
    
    .btn-receive-all {
        justify-content: center;
    }
    
    .header-badge {
        display: none;
    }
}

@keyframes spin {
    to { transform: rotate(360deg); }
}

/* Search dropdown empty state */
.search-dropdown-empty {
    padding: 10px 14px;
    color: rgba(255,255,255,0.3);
    font-size: 13px;
    text-align: center;
    background: #1A2332;
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 8px;
    margin-top: 4px;
}

/* Receive Actions Row */
.receive-actions-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 4px;
}

.btn-add-to-list {
    padding: 8px 16px;
    background: linear-gradient(135deg, #D69E2E, #ECC94B);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-add-to-list:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(214, 158, 46, 0.25);
}

.btn-add-to-list:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-receive-now {
    padding: 8px 16px;
    background: linear-gradient(135deg, #10B981, #059669);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-receive-now:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.25);
}

.btn-receive-now:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Responsive */
@media (max-width: 768px) {
    .receive-actions-row {
        grid-template-columns: 1fr;
    }
}

/* ============================================================
   ISSUE STOCK PAGE
   ============================================================ */

.issue-stock-wrapper {
    min-height: 100vh;
    height: 100vh;
    background: #0A0F1E;
    color: #FFFFFF;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* Header */
.issue-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 24px;
    background: rgba(10, 15, 30, 0.95);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
    backdrop-filter: blur(10px);
    z-index: 10;
}

.header-badge {
    background: rgba(239, 68, 68, 0.12);
    color: #EF4444;
    padding: 2px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    border: 1px solid rgba(239, 68, 68, 0.1);
}

/* Content */
.issue-content {
    flex: 1;
    padding: 16px 24px 20px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(239, 68, 68, 0.2) transparent;
}

.issue-content::-webkit-scrollbar {
    width: 6px;
}

.issue-content::-webkit-scrollbar-track {
    background: transparent;
}

.issue-content::-webkit-scrollbar-thumb {
    background: rgba(239, 68, 68, 0.15);
    border-radius: 3px;
}

.issue-content::-webkit-scrollbar-thumb:hover {
    background: rgba(239, 68, 68, 0.3);
}

.issue-page-header {
    margin-bottom: 16px;
}

.issue-page-header h1 {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    color: #FFFFFF;
}

.issue-page-header p {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    margin: 2px 0 0 0;
}

/* Grid */
.issue-grid {
    display: grid;
    grid-template-columns: 0.9fr 1.1fr;
    gap: 20px;
    height: calc(100vh - 200px);
}

.issue-left {
    display: flex;
    flex-direction: column;
    gap: 14px;
}

.issue-right {
    display: flex;
    flex-direction: column;
    min-height: 0;
}

/* Cards */
.issue-card {
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    padding: 16px 18px;
}

.card-title {
    font-size: 14px;
    font-weight: 600;
    margin: 0 0 12px 0;
    color: #FFFFFF;
    display: flex;
    align-items: center;
    gap: 8px;
}

/* Buttons */
.btn-add-to-list {
    width: 100%;
    padding: 8px 16px;
    background: linear-gradient(135deg, #EF4444, #DC2626);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-add-to-list:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(239, 68, 68, 0.25);
}

.btn-add-to-list:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-issue-all {
    padding: 6px 20px;
    background: linear-gradient(135deg, #EF4444, #DC2626);
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-issue-all:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(239, 68, 68, 0.25);
}

.btn-issue-all:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Items count */
.items-count {
    background: rgba(239, 68, 68, 0.1);
    color: #EF4444;
    padding: 0px 10px;
    border-radius: 12px;
    font-size: 12px;
}

/* Table - Issue specific */
.items-table th:last-child {
    width: 40px;
}

.current-stock {
    color: #10B981;
    font-weight: 600;
}

/* Empty state - update icon color */
.empty-state svg {
    stroke: rgba(239, 68, 68, 0.08);
}

/* Responsive */
@media (max-width: 1024px) {
    .issue-grid {
        grid-template-columns: 1fr;
        height: auto;
    }
    
    .issue-right {
        min-height: 300px;
    }
}

@media (max-width: 768px) {
    .issue-header {
        padding: 8px 16px;
        flex-wrap: wrap;
        gap: 8px;
    }
    
    .issue-content {
        padding: 12px 14px 16px;
    }
    
    .form-row-3 {
        grid-template-columns: 1fr;
        gap: 6px;
    }
    
    .items-table-wrapper {
        overflow-x: auto;
    }
    
    .items-table {
        font-size: 11px;
        min-width: 600px;
    }
    
    .items-summary {
        flex-direction: column;
        gap: 8px;
        align-items: stretch;
    }
    
    .btn-issue-all {
        justify-content: center;
    }
}

/* Batch Defaults for Issue */
.batch-defaults-row {
    display: grid;
    grid-template-columns: 1fr 1fr auto;
    gap: 10px;
    align-items: end;
}

.card-header {
    display: flex;
    align-items: center;
    gap: 10px;
    margin-bottom: 10px;
}

.card-header h3 {
    font-size: 14px;
    font-weight: 600;
    margin: 0;
    color: rgba(255,255,255,0.6);
}

.card-badge {
    font-size: 10px;
    color: rgba(255,255,255,0.2);
    background: rgba(255,255,255,0.04);
    padding: 1px 10px;
    border-radius: 12px;
}

.btn-apply-defaults {
    padding: 6px 16px;
    background: rgba(239, 68, 68, 0.08);
    border: 1px solid rgba(239, 68, 68, 0.06);
    border-radius: 6px;
    color: #EF4444;
    font-size: 12px;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    white-space: nowrap;
    height: 38px;
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-apply-defaults:hover:not(:disabled) {
    background: rgba(239, 68, 68, 0.15);
}

.btn-apply-defaults:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

/* Issue Actions Row */
.issue-actions-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 4px;
}

.btn-add-to-list {
    padding: 8px 16px;
    background: linear-gradient(135deg, #EF4444, #DC2626);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-add-to-list:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(239, 68, 68, 0.25);
}

.btn-add-to-list:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-issue-now {
    padding: 8px 16px;
    background: linear-gradient(135deg, #10B981, #059669);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-issue-now:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.25);
}

.btn-issue-now:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-issue-all {
    padding: 6px 20px;
    background: linear-gradient(135deg, #EF4444, #DC2626);
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-issue-all:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(239, 68, 68, 0.25);
}

.btn-issue-all:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Responsive */
@media (max-width: 768px) {
    .batch-defaults-row {
        grid-template-columns: 1fr;
    }
    
    .issue-actions-row {
        grid-template-columns: 1fr;
    }
}

