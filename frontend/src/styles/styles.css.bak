}

.btn-apply-defaults:hover:not(:disabled) {
    background: rgba(16, 185, 129, 0.15);
}

.btn-apply-defaults:disabled {
    opacity: 0.4;
    cursor: not-allowed;
}

/* Dispense Actions Row */
.dispense-actions-row {
    display: grid;
    grid-template-columns: 1fr 1fr;
    gap: 10px;
    margin-top: 4px;
}

.btn-add-to-list {
    padding: 8px 16px;
    background: linear-gradient(135deg, #D69E2E, #ECC94B);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-add-to-list:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(214, 158, 46, 0.25);
}

.btn-add-to-list:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-dispense-now {
    padding: 8px 16px;
    background: linear-gradient(135deg, #10B981, #059669);
    color: #FFFFFF;
    border: none;
    border-radius: 8px;
    font-size: 13px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    justify-content: center;
    gap: 8px;
    height: 38px;
}

.btn-dispense-now:hover:not(:disabled) {
    transform: translateY(-1px);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.25);
}

.btn-dispense-now:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

.btn-dispense-all {
    padding: 6px 20px;
    background: linear-gradient(135deg, #10B981, #059669);
    color: #FFFFFF;
    border: none;
    border-radius: 6px;
    font-size: 12px;
    font-weight: 600;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    display: flex;
    align-items: center;
    gap: 6px;
}

.btn-dispense-all:hover:not(:disabled) {
    transform: translateY(-2px);
    box-shadow: 0 8px 30px rgba(16, 185, 129, 0.25);
}

.btn-dispense-all:disabled {
    opacity: 0.5;
    cursor: not-allowed;
}

/* Items count */
.items-count {
    background: rgba(16, 185, 129, 0.1);
    color: #10B981;
    padding: 0px 10px;
    border-radius: 12px;
    font-size: 12px;
}

.current-stock {
    color: #10B981;
    font-weight: 600;
}

/* Empty state */
.empty-state svg {
    stroke: rgba(16, 185, 129, 0.08);
}

/* Responsive */
@media (max-width: 1024px) {
    .dispense-grid {
        grid-template-columns: 1fr;
        height: auto;
    }
    
    .dispense-right {
        min-height: 300px;
    }
}

@media (max-width: 768px) {
    .dispense-header {
        padding: 8px 16px;
        flex-wrap: wrap;
        gap: 8px;
    }
    
    .dispense-content {
        padding: 12px 14px 16px;
    }
    
    .form-row-3 {
        grid-template-columns: 1fr;
        gap: 6px;
    }
    
    .batch-defaults-row {
        grid-template-columns: 1fr;
    }
    
    .dispense-actions-row {
        grid-template-columns: 1fr;
    }
    
    .items-table-wrapper {
        overflow-x: auto;
    }
    
    .items-table {
        font-size: 11px;
        min-width: 600px;
    }
    
    .items-summary {
        flex-direction: column;
        gap: 8px;
        align-items: stretch;
    }
    
    .btn-dispense-all {
        justify-content: center;
    }
}

/* ============================================================
   SEARCH PRODUCTS PAGE
   ============================================================ */

.search-wrapper {
    min-height: 100vh;
    height: 100vh;
    background: #0A0F1E;
    color: #FFFFFF;
    display: flex;
    flex-direction: column;
    overflow: hidden;
    font-family: -apple-system, BlinkMacSystemFont, 'Segoe UI', Roboto, sans-serif;
}

/* Header */
.search-header {
    display: flex;
    justify-content: space-between;
    align-items: center;
    padding: 10px 24px;
    background: rgba(10, 15, 30, 0.95);
    border-bottom: 1px solid rgba(255,255,255,0.04);
    flex-shrink: 0;
    backdrop-filter: blur(10px);
    z-index: 10;
}

.header-badge {
    background: rgba(139, 92, 246, 0.12);
    color: #8B5CF6;
    padding: 2px 14px;
    border-radius: 20px;
    font-size: 11px;
    font-weight: 600;
    border: 1px solid rgba(139, 92, 246, 0.1);
}

/* Content */
.search-content {
    flex: 1;
    padding: 16px 24px 20px;
    overflow-y: auto;
    scrollbar-width: thin;
    scrollbar-color: rgba(139, 92, 246, 0.2) transparent;
}

.search-content::-webkit-scrollbar {
    width: 6px;
}

.search-content::-webkit-scrollbar-track {
    background: transparent;
}

.search-content::-webkit-scrollbar-thumb {
    background: rgba(139, 92, 246, 0.15);
    border-radius: 3px;
}

.search-content::-webkit-scrollbar-thumb:hover {
    background: rgba(139, 92, 246, 0.3);
}

.search-page-header {
    margin-bottom: 16px;
}

.search-page-header h1 {
    font-size: 22px;
    font-weight: 700;
    margin: 0;
    color: #FFFFFF;
    display: flex;
    align-items: center;
    gap: 10px;
}

.search-page-header p {
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    margin: 2px 0 0 0;
}

/* Search Bar */
.search-bar-wrapper {
    display: flex;
    gap: 12px;
    margin-bottom: 12px;
}

.search-input-wrapper {
    flex: 1;
    position: relative;
    display: flex;
    align-items: center;
}

.search-input-wrapper svg {
    position: absolute;
    left: 14px;
    color: rgba(255,255,255,0.2);
}

.search-input {
    width: 100%;
    padding: 10px 14px 10px 44px;
    background: rgba(255,255,255,0.04);
    border: 1px solid rgba(255,255,255,0.06);
    border-radius: 10px;
    color: #FFFFFF;
    font-size: 14px;
    font-family: inherit;
    outline: none;
    transition: all 0.3s ease;
    height: 44px;
}

.search-input:focus {
    border-color: rgba(139, 92, 246, 0.3);
    background: rgba(255,255,255,0.06);
    box-shadow: 0 0 0 3px rgba(139, 92, 246, 0.05);
}

.search-input::placeholder {
    color: rgba(255,255,255,0.15);
}

.search-clear-btn {
    position: absolute;
    right: 12px;
    background: none;
    border: none;
    color: rgba(255,255,255,0.2);
    cursor: pointer;
    padding: 4px;
    transition: color 0.3s ease;
    display: flex;
    align-items: center;
}

.search-clear-btn:hover {
    color: rgba(255,255,255,0.6);
}

.search-filter-toggle {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 10px 18px;
    background: rgba(139, 92, 246, 0.06);
    border: 1px solid rgba(139, 92, 246, 0.06);
    border-radius: 10px;
    color: rgba(255,255,255,0.5);
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    font-size: 13px;
    height: 44px;
    white-space: nowrap;
    position: relative;
}

.search-filter-toggle:hover {
    background: rgba(139, 92, 246, 0.1);
    color: rgba(255,255,255,0.8);
}

.filter-badge {
    background: #8B5CF6;
    color: #FFFFFF;
    font-size: 10px;
    font-weight: 700;
    padding: 1px 6px;
    border-radius: 10px;
    margin-left: 4px;
}

/* Filters */
.search-filters {
    display: flex;
    flex-wrap: wrap;
    gap: 8px;
    margin-bottom: 14px;
    padding: 12px 16px;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 10px;
    align-items: center;
}

.filter-btn {
    display: flex;
    align-items: center;
    gap: 6px;
    padding: 6px 14px;
    background: rgba(255,255,255,0.03);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 6px;
    color: rgba(255,255,255,0.4);
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    font-size: 12px;
}

.filter-btn:hover {
    background: rgba(255,255,255,0.06);
    color: rgba(255,255,255,0.7);
}

.filter-btn.active {
    background: rgba(139, 92, 246, 0.1);
    border-color: rgba(139, 92, 246, 0.15);
    color: #8B5CF6;
}

.filter-icon {
    display: flex;
    align-items: center;
}

.filter-clear {
    display: flex;
    align-items: center;
    gap: 4px;
    padding: 6px 14px;
    background: rgba(239, 68, 68, 0.06);
    border: 1px solid rgba(239, 68, 68, 0.08);
    border-radius: 6px;
    color: #EF4444;
    cursor: pointer;
    transition: all 0.3s ease;
    font-family: inherit;
    font-size: 12px;
    margin-left: auto;
}

.filter-clear:hover {
    background: rgba(239, 68, 68, 0.12);
}

/* Results Count */
.search-results-count {
    display: flex;
    gap: 10px;
    font-size: 13px;
    color: rgba(255,255,255,0.3);
    margin-bottom: 12px;
}

.search-term {
    color: rgba(255,255,255,0.5);
}

.search-filter-label {
    color: #8B5CF6;
}

/* Results Table */
.search-results-wrapper {
    flex: 1;
    background: rgba(255,255,255,0.02);
    border: 1px solid rgba(255,255,255,0.04);
    border-radius: 12px;
    overflow: hidden;
    min-height: 300px;
}

.search-table-wrapper {
    overflow-x: auto;
    height: 100%;
}

.search-table {
    width: 100%;
    border-collapse: collapse;
    font-size: 13px;
}

.search-table thead {
    background: rgba(255,255,255,0.02);
    border-bottom: 1px solid rgba(255,255,255,0.04);
}

.search-table th {
    text-align: left;
    padding: 12px 16px;
    color: rgba(255,255,255,0.3);
    font-weight: 600;
    font-size: 11px;
    text-transform: uppercase;
    letter-spacing: 0.5px;
}

.search-table td {
    padding: 10px 16px;
    border-bottom: 1px solid rgba(255,255,255,0.02);
    color: rgba(255,255,255,0.7);
}

.search-table tr:hover td {
    background: rgba(255,255,255,0.02);
}

.product-cell .product-name {
    color: #FFFFFF;
    font-weight: 500;
}

.product-detail {
    font-size: 12px;
    color: rgba(255,255,255,0.3);
    margin-top: 2px;
}

.product-category {
    margin-left: 4px;
}

.product-code {
    font-family: monospace;
    font-size: 12px;
    color: rgba(255,255,255,0.3);
}

.product-stock {
    font-weight: 600;
}

.stock-status {
    padding: 2px 12px;
    border-radius: 12px;
    font-size: 11px;
    font-weight: 500;
    display: inline-block;
}

.product-price {
    color: #D69E2E;
    font-weight: 500;
}

.product-actions {
    display: flex;
    gap: 4px;
}

.action-btn {
    background: none;
    border: none;
    color: rgba(255,255,255,0.15);
    cursor: pointer;
    padding: 4px 6px;
    border-radius: 4px;
    transition: all 0.3s ease;
    display: flex;
    align-items: center;
}

.action-btn:hover {
    background: rgba(255,255,255,0.05);
    color: rgba(255,255,255,0.5);
}

.view-btn:hover {
    color: #8B5CF6;
}

.edit-btn:hover {
    color: #D69E2E;
}

/* Loading / Empty */
.search-loading {
    display: flex;
    align-items: center;
    justify-content: center;
    height: 200px;
    color: rgba(255,255,255,0.2);
    font-size: 14px;
}

.search-empty {
    display: flex;
    flex-direction: column;
    align-items: center;
    justify-content: center;
    height: 250px;
    color: rgba(255,255,255,0.2);
}

.search-empty svg {
    width: 48px;
    height: 48px;
    stroke: rgba(255,255,255,0.08);
    margin-bottom: 12px;
}

.search-empty p {
    font-size: 16px;
    font-weight: 500;
    color: rgba(255,255,255,0.3);
    margin: 0;
}

.search-empty span {
    font-size: 13px;
    opacity: 0.4;
}

/* Responsive */
@media (max-width: 768px) {
    .search-header {
        padding: 8px 16px;
        flex-wrap: wrap;
        gap: 8px;
    }
    
    .search-content {
        padding: 12px 14px 16px;
    }
    
    .search-bar-wrapper {
        flex-direction: column;
    }
    
    .search-filters {
        flex-wrap: wrap;
    }
    
    .filter-clear {
        margin-left: 0;
        width: 100%;
        justify-content: center;
    }
    
    .search-table {
        font-size: 12px;
        min-width: 600px;
    }
    
    .search-table th,
    .search-table td {
        padding: 8px 12px;
    }
    
    .search-page-header h1 {
        font-size: 20px;
    }
}
