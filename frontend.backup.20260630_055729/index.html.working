<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0, maximum-scale=1.0, user-scalable=no" />
    <title>Medox Pharmacy</title>
    <link href="https://fonts.googleapis.com/css2?family=Inter:wght@300;400;500;600;700;800;900&display=swap" rel="stylesheet" />
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.4.0/css/all.min.css" />
    <style>
        * { margin: 0; padding: 0; box-sizing: border-box; }
        :root {
            --gold: #D69E2E;
            --gold-light: #ECC94B;
            --gold-dark: #B7791F;
            --dark: #0A0F1E;
            --dark-card: #111827;
            --dark-hover: #1A2332;
            --white: #FFFFFF;
            --text-muted: rgba(255,255,255,0.4);
            --text-light: rgba(255,255,255,0.7);
            --danger: #EF4444;
            --success: #10B981;
            --warning: #F59E0B;
            --font: 'Inter', -apple-system, BlinkMacSystemFont, sans-serif;
            --radius: 12px;
            --radius-lg: 16px;
            --shadow: 0 8px 32px rgba(0,0,0,0.3);
        }
        html, body {
            height: 100%;
            font-family: var(--font);
            background: var(--dark);
            color: var(--white);
            overflow: hidden;
        }
        ::-webkit-scrollbar { display: none; }
        * { scrollbar-width: none; }
        .page { display: none !important; height: 100vh; width: 100vw; position: fixed; top: 0; left: 0; overflow: hidden; flex-direction: column; background: var(--dark); z-index: 1; }
        .page.active { display: flex !important; z-index: 10; }
        
        /* Dashboard Header */
        .dash-header {
            padding: 14px 32px;
            display: flex;
            justify-content: space-between;
            align-items: center;
            border-bottom: 1px solid rgba(255,255,255,0.04);
            background: rgba(13, 18, 30, 0.4);
            backdrop-filter: blur(12px);
            flex-shrink: 0;
        }
        .dash-header .brand {
            display: flex;
            align-items: center;
            gap: 10px;
        }
        .dash-header .brand .icon {
            width: 32px;
            height: 32px;
            background: rgba(214, 158, 46, 0.08);
            border-radius: 8px;
            display: flex;
            align-items: center;
            justify-content: center;
            color: var(--gold);
            font-size: 14px;
        }
        .dash-header .brand .name {
            font-size: 16px;
            font-weight: 700;
        }
        .dash-header .brand .name span {
            color: var(--gold);
        }
        .dash-header .user-section {
            display: flex;
            align-items: center;
            gap: 14px;
        }
        .dash-header .user-section .logout-btn {
            background: none;
            border: none;
            color: var(--text-muted);
            cursor: pointer;
            font-size: 16px;
            padding: 4px 6px;
            transition: 0.3s;
            border-radius: 6px;
        }
        .dash-header .user-section .logout-btn:hover {
            color: var(--danger);
        }
        
        /* Main Content */
        .dash-main {
            flex: 1;
            overflow: hidden;
            padding: 20px 32px 70px;
        }
        
        /* Bottom Nav */
        .bottom-nav {
            position: fixed;
            bottom: 0;
            left: 0;
            right: 0;
            background: rgba(13, 18, 30, 0.95);
            backdrop-filter: blur(20px);
            border-top: 1px solid rgba(255,255,255,0.04);
            display: flex;
            justify-content: space-around;
            padding: 6px 0 env(safe-area-inset-bottom, 6px) 0;
            z-index: 100;
        }
        .bottom-nav .nav-item {
            display: flex;
            flex-direction: column;
            align-items: center;
            gap: 1px;
            padding: 4px 14px;
            border: none;
            background: none;
            cursor: pointer;
            color: var(--text-muted);
            font-family: var(--font);
            font-size: 9px;
            font-weight: 500;
            transition: 0.3s;
            position: relative;
            border-radius: 6px;
        }
        .bottom-nav .nav-item.active {
            color: var(--gold);
        }
        .bottom-nav .nav-item i {
            font-size: 18px;
        }
        
        /* Receive Stock Form */
        .receive-container {
            max-width: 1200px;
            margin: 0 auto;
            width: 100%;
            flex: 1;
            display: flex;
            flex-direction: column;
        }
        .receive-form {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 14px;
            padding: 24px 28px;
            flex: 1;
            display: flex;
            flex-direction: column;
            overflow: hidden;
        }
        .receive-grid {
            display: grid;
            grid-template-columns: 1fr 1fr 1fr;
            gap: 20px;
            flex: 1;
        }
        .receive-grid .col {
            display: flex;
            flex-direction: column;
            gap: 12px;
        }
        .receive-grid label {
            display: block;
            font-size: 11px;
            font-weight: 600;
            color: var(--text-muted);
            margin-bottom: 4px;
        }
        .receive-grid input, .receive-grid select {
            width: 100%;
            padding: 10px 14px;
            font-size: 14px;
            background: rgba(255,255,255,0.03);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 8px;
            color: var(--white);
            font-family: var(--font);
            outline: none;
            transition: 0.3s;
        }
        .receive-grid select option {
            background: #1A2332;
            color: #FFFFFF;
        }
        .receive-grid .info-box {
            background: rgba(255,255,255,0.02);
            border: 1px solid rgba(255,255,255,0.04);
            border-radius: 8px;
            padding: 12px 16px;
        }
        .receive-grid .info-box .row {
            display: flex;
            justify-content: space-between;
            font-size: 12px;
        }
        .receive-grid .info-box .row .label {
            color: var(--text-muted);
        }
        .receive-grid .info-box .row .value {
            font-weight: 600;
            color: var(--gold);
        }
        .btn-gold {
            padding: 12px 20px;
            background: linear-gradient(135deg, var(--gold), var(--gold-light));
            color: var(--white);
            border: none;
            border-radius: 8px;
            font-family: var(--font);
            font-size: 14px;
            font-weight: 600;
            cursor: pointer;
            transition: 0.3s;
            box-shadow: 0 4px 20px rgba(214,158,46,0.2);
        }
        .btn-gold:hover {
            transform: translateY(-2px);
            box-shadow: 0 8px 30px rgba(214,158,46,0.35);
        }
        .btn-secondary {
            padding: 12px 20px;
            background: rgba(255,255,255,0.04);
            color: var(--text-muted);
            border: 1px solid rgba(255,255,255,0.06);
            border-radius: 8px;
            font-family: var(--font);
            font-size: 14px;
            font-weight: 500;
            cursor: pointer;
            transition: 0.3s;
        }
        .btn-secondary:hover {
            background: rgba(255,255,255,0.08);
        }
        .btn-row {
            display: flex;
            gap: 12px;
            margin-top: auto;
            padding-top: 12px;
            border-top: 1px solid rgba(255,255,255,0.04);
        }
        .btn-row .flex-1 { flex: 1; }
    </style>
</head>
<body>

<!-- DASHBOARD PAGE -->
<div class="page active" id="dashboardPage">
    <header class="dash-header">
        <div class="brand">
            <div class="icon"><i class="fas fa-prescription-bottle-alt"></i></div>
            <span class="name">Medox<span>Pharmacy</span></span>
        </div>
        <div class="user-section">
            <button class="logout-btn" onclick="logout()"><i class="fas fa-sign-out-alt"></i></button>
        </div>
    </header>
    <main class="dash-main">
        <h1>Dashboard</h1>
        <p style="color:var(--text-muted);">Welcome to Medox Pharmacy</p>
        <div style="margin-top:20px;display:flex;gap:12px;flex-wrap:wrap;">
            <button onclick="navigateTo('receiveStock')" class="btn-gold"><i class="fas fa-arrow-down"></i> Receive Stock</button>
            <button onclick="navigateTo('issueStock')" class="btn-secondary"><i class="fas fa-arrow-up"></i> Issue Stock</button>
            <button onclick="navigateTo('addProduct')" class="btn-secondary"><i class="fas fa-plus"></i> Add Product</button>
            <button onclick="navigateTo('search')" class="btn-secondary"><i class="fas fa-search"></i> Search</button>
        </div>
    </main>
    <nav class="bottom-nav">
        <button class="nav-item active" onclick="navigateTo('dashboard')"><i class="fas fa-home"></i><span>Home</span></button>
        <button class="nav-item" onclick="navigateTo('receiveStock')"><i class="fas fa-arrow-down"></i><span>Receive</span></button>
        <button class="nav-item" onclick="navigateTo('issueStock')"><i class="fas fa-arrow-up"></i><span>Issue</span></button>
        <button class="nav-item" onclick="navigateTo('search')"><i class="fas fa-search"></i><span>Search</span></button>
        <button class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></button>
    </nav>
</div>

<!-- RECEIVE STOCK PAGE -->
<div class="page" id="receiveStockPage">
    <header class="dash-header">
        <div class="brand">
            <div class="icon"><i class="fas fa-arrow-down" style="color:var(--gold);"></i></div>
            <span class="name">Receive<span style="color:var(--gold);">Stock</span></span>
        </div>
        <div class="user-section">
            <button class="logout-btn" onclick="navigateTo('dashboard')" style="font-size:13px;display:flex;align-items:center;gap:6px;"><i class="fas fa-arrow-left"></i> Back</button>
        </div>
    </header>
    <main class="dash-main">
        <div class="receive-container">
            <div style="display:flex;justify-content:space-between;align-items:center;margin-bottom:16px;flex-shrink:0;">
                <div>
                    <h1 style="font-size:22px;font-weight:800;">Receive Stock</h1>
                    <p style="color:var(--text-muted);font-size:13px;">Add stock to existing products</p>
                </div>
            </div>
            <div class="receive-form">
                <div class="receive-grid">
                    <!-- Column 1: Product Selection -->
                    <div class="col">
                        <div style="font-size:13px;font-weight:600;color:var(--gold);"><i class="fas fa-search"></i> Select Product</div>
                        <div>
                            <label>Search Product</label>
                            <input type="text" id="receiveSearch" placeholder="Type product name..." oninput="searchProductsForReceive(this.value)" />
                        </div>
                        <div>
                            <label>Select Product <span style="color:#EF4444;">*</span></label>
                            <select id="receiveProduct">
                                <option value="">Loading products...</option>
                            </select>
                        </div>
                        <div class="info-box">
                            <div class="row"><span class="label">Current Stock:</span><span class="value" id="receiveCurrentStock">0</span></div>
                            <div class="row" style="margin-top:4px;"><span class="label">Product Code:</span><span class="value" id="receiveProductCode">—</span></div>
                        </div>
                    </div>
                    
                    <!-- Column 2: Stock Details -->
                    <div class="col">
                        <div style="font-size:13px;font-weight:600;color:var(--gold);"><i class="fas fa-boxes"></i> Stock Details</div>
                        <div>
                            <label>Quantity Received <span style="color:#EF4444;">*</span></label>
                            <input type="number" id="receiveQty" placeholder="0" min="1" />
                        </div>
                        <div>
                            <label>Batch Number <span style="color:#EF4444;">*</span></label>
                            <input type="text" id="receiveBatch" placeholder="e.g. B-2026-001" />
                        </div>
                        <div>
                            <label>Expiry Date <span style="color:#EF4444;">*</span></label>
                            <input type="date" id="receiveExpiry" />
                        </div>
                    </div>
                    
                    <!-- Column 3: Additional Info -->
                    <div class="col">
                        <div style="font-size:13px;font-weight:600;color:var(--gold);"><i class="fas fa-info-circle"></i> Additional Info</div>
                        <div>
                            <label>D. Note / RIV Number</label>
                            <input type="text" id="receiveDNote" placeholder="e.g. DN-2026-001" />
                        </div>
                        <div>
                            <label>Supplier / From</label>
                            <input type="text" id="receiveSupplier" placeholder="e.g. MediSupply Ltd" />
                        </div>
                        <div>
                            <label>Remarks</label>
                            <input type="text" id="receiveRemarks" placeholder="Any notes..." />
                        </div>
                        <div class="btn-row">
                            <button onclick="submitReceiveStock()" class="btn-gold flex-1"><i class="fas fa-arrow-down"></i> Receive Stock</button>
                            <button onclick="clearReceiveForm()" class="btn-secondary"><i class="fas fa-undo"></i> Clear</button>
                        </div>
                    </div>
                </div>
            </div>
        </div>
    </main>
    <nav class="bottom-nav">
        <button class="nav-item" onclick="navigateTo('dashboard')"><i class="fas fa-home"></i><span>Home</span></button>
        <button class="nav-item active" onclick="navigateTo('receiveStock')"><i class="fas fa-arrow-down" style="color:var(--gold);"></i><span>Receive</span></button>
        <button class="nav-item" onclick="navigateTo('issueStock')"><i class="fas fa-arrow-up"></i><span>Issue</span></button>
        <button class="nav-item" onclick="navigateTo('search')"><i class="fas fa-search"></i><span>Search</span></button>
        <button class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></button>
    </nav>
</div>

<!-- ISSUE STOCK PAGE (placeholder) -->
<div class="page" id="issueStockPage">
    <header class="dash-header">
        <div class="brand">
            <div class="icon"><i class="fas fa-arrow-up" style="color:var(--gold);"></i></div>
            <span class="name">Issue<span style="color:var(--gold);">Stock</span></span>
        </div>
        <div class="user-section">
            <button class="logout-btn" onclick="navigateTo('dashboard')" style="font-size:13px;display:flex;align-items:center;gap:6px;"><i class="fas fa-arrow-left"></i> Back</button>
        </div>
    </header>
    <main class="dash-main">
        <h1>Issue Stock</h1>
        <p style="color:var(--text-muted);">Coming soon...</p>
    </main>
    <nav class="bottom-nav">
        <button class="nav-item" onclick="navigateTo('dashboard')"><i class="fas fa-home"></i><span>Home</span></button>
        <button class="nav-item" onclick="navigateTo('receiveStock')"><i class="fas fa-arrow-down"></i><span>Receive</span></button>
        <button class="nav-item active" onclick="navigateTo('issueStock')"><i class="fas fa-arrow-up" style="color:var(--gold);"></i><span>Issue</span></button>
        <button class="nav-item" onclick="navigateTo('search')"><i class="fas fa-search"></i><span>Search</span></button>
        <button class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></button>
    </nav>
</div>

<!-- SEARCH PAGE (placeholder) -->
<div class="page" id="searchPage">
    <header class="dash-header">
        <div class="brand">
            <div class="icon"><i class="fas fa-search" style="color:var(--gold);"></i></div>
            <span class="name">Search<span style="color:var(--gold);">Products</span></span>
        </div>
        <div class="user-section">
            <button class="logout-btn" onclick="navigateTo('dashboard')" style="font-size:13px;display:flex;align-items:center;gap:6px;"><i class="fas fa-arrow-left"></i> Back</button>
        </div>
    </header>
    <main class="dash-main">
        <h1>Search Products</h1>
        <p style="color:var(--text-muted);">Coming soon...</p>
    </main>
    <nav class="bottom-nav">
        <button class="nav-item" onclick="navigateTo('dashboard')"><i class="fas fa-home"></i><span>Home</span></button>
        <button class="nav-item" onclick="navigateTo('receiveStock')"><i class="fas fa-arrow-down"></i><span>Receive</span></button>
        <button class="nav-item" onclick="navigateTo('issueStock')"><i class="fas fa-arrow-up"></i><span>Issue</span></button>
        <button class="nav-item active" onclick="navigateTo('search')"><i class="fas fa-search" style="color:var(--gold);"></i><span>Search</span></button>
        <button class="nav-item"><i class="fas fa-cog"></i><span>Settings</span></button>
    </nav>
</div>

<script>
// ============================================================
// API URL
// ============================================================
const API_URL = window.location.origin;

// ============================================================
// NAVIGATION
// ============================================================
function navigateTo(pageId) {
    console.log('Navigating to:', pageId);
    document.querySelectorAll('.page').forEach(function(p) {
        p.classList.remove('active');
    });
    
    var pageMap = {
        'dashboard': 'dashboardPage',
        'receiveStock': 'receiveStockPage',
        'issueStock': 'issueStockPage',
        'search': 'searchPage'
    };
    
    var targetId = pageMap[pageId];
    if (targetId) {
        var target = document.getElementById(targetId);
        if (target) {
            target.classList.add('active');
            console.log('Showing:', targetId);
            if (pageId === 'receiveStock') {
                setTimeout(loadReceiveProducts, 300);
            }
        }
    }
}

// ============================================================
// LOGOUT
// ============================================================
function logout() {
    if (confirm('Are you sure you want to logout?')) {
        localStorage.removeItem('token');
        localStorage.removeItem('user');
        navigateTo('dashboard');
    }
}

// ============================================================
// RECEIVE STOCK FUNCTIONS
// ============================================================
var productsCache = [];

function loadReceiveProducts() {
    var token = localStorage.getItem('token');
    if (!token) {
        console.log('No token found, redirecting to login');
        // Try to get token from login
        return;
    }

    console.log('Loading products for receive...');
    fetch(API_URL + '/api/products', {
        headers: { 'Authorization': 'Bearer ' + token }
    })
    .then(function(response) {
        if (response.status === 401) {
            localStorage.removeItem('token');
            alert('Please login again.');
            return;
        }
        return response.json();
    })
    .then(function(data) {
        if (data && data.success) {
            productsCache = data.data;
            console.log('Loaded ' + productsCache.length + ' products');
            populateReceiveDropdown(productsCache);
        }
    })
    .catch(function(error) {
        console.error('Error loading products:', error);
    });
}

function populateReceiveDropdown(products) {
    var select = document.getElementById('receiveProduct');
    if (!select) {
        console.error('receiveProduct element not found!');
        return;
    }

    select.innerHTML = '<option value="">Select a product...</option>';
    if (!products || products.length === 0) {
        select.innerHTML = '<option value="">No products available</option>';
        return;
    }
    
    products.forEach(function(p) {
        var option = document.createElement('option');
        option.value = p._id;
        var stock = p.quantityOnHand || 0;
        var code = p.code || 'N/A';
        option.textContent = p.name + ' ' + (p.strength || '') + ' | Stock: ' + stock + ' | Code: ' + code;
        select.appendChild(option);
    });
    console.log('Dropdown populated with ' + products.length + ' products');
}

function searchProductsForReceive(query) {
    var select = document.getElementById('receiveProduct');
    if (!select) return;

    var searchTerm = query.toLowerCase().trim();
    if (!searchTerm) {
        populateReceiveDropdown(productsCache);
        return;
    }
    
    var filtered = productsCache.filter(function(p) {
        var name = (p.name || '').toLowerCase();
        var strength = (p.strength || '').toLowerCase();
        var code = (p.code || '').toLowerCase();
        var category = (p.category || '').toLowerCase();
        return name.includes(searchTerm) || strength.includes(searchTerm) ||
               code.includes(searchTerm) || category.includes(searchTerm);
    });
    
    populateReceiveDropdown(filtered);
    if (filtered.length === 1) {
        select.value = filtered[0]._id;
        updateReceiveProductInfo(filtered[0]);
    }
}

function updateReceiveProductInfo(product) {
    var stockEl = document.getElementById('receiveCurrentStock');
    var codeEl = document.getElementById('receiveProductCode');
    if (stockEl) stockEl.textContent = product.quantityOnHand || 0;
    if (codeEl) codeEl.textContent = product.code || '—';
}

function submitReceiveStock() {
    var productId = document.getElementById('receiveProduct').value;
    var qty = parseInt(document.getElementById('receiveQty').value);
    var batch = document.getElementById('receiveBatch').value.trim();
    var expiry = document.getElementById('receiveExpiry').value;
    var dNote = document.getElementById('receiveDNote').value.trim();
    var supplier = document.getElementById('receiveSupplier').value.trim();
    var remarks = document.getElementById('receiveRemarks').value.trim();

    if (!productId) {
        alert('Please select a product.');
        return;
    }
    if (!qty || qty <= 0) {
        alert('Please enter a valid quantity.');
        return;
    }
    if (!batch) {
        alert('Please enter a batch number.');
        return;
    }
    if (!expiry) {
        alert('Please select an expiry date.');
        return;
    }

    var token = localStorage.getItem('token');
    if (!token) {
        alert('Please login first.');
        return;
    }

    var product = productsCache.find(function(p) { return p._id === productId; });
    if (!product) {
        alert('Product not found.');
        return;
    }

    var newStock = (product.quantityOnHand || 0) + qty;

    var btn = document.querySelector('#receiveStockPage .btn-gold');
    if (btn) {
        btn.innerHTML = '<i class="fas fa-spinner fa-spin"></i> Processing...';
        btn.disabled = true;
    }

    fetch(API_URL + '/api/products/' + productId, {
        method: 'PUT',
        headers: {
            'Authorization': 'Bearer ' + token,
            'Content-Type': 'application/json'
        },
        body: JSON.stringify({
            quantityReceived: qty,
            quantityOnHand: newStock,
            batchNumber: batch,
            expiryDate: expiry,
            dNote: dNote,
            supplier: supplier,
            remarks: remarks
        })
    })
    .then(function(response) { return response.json(); })
    .then(function(data) {
        if (data.success) {
            alert('✅ Stock received successfully!\n\n' +
                  'Product: ' + data.data.name + ' ' + (data.data.strength || '') + '\n' +
                  'New Stock: ' + data.data.quantityOnHand + ' units\n' +
                  'Batch: ' + data.data.batchNumber + '\n' +
                  'Expiry: ' + new Date(data.data.expiryDate).toLocaleDateString());
            clearReceiveForm();
            loadReceiveProducts();
        } else {
            alert('❌ Error: ' + (data.message || 'Unknown error'));
        }
    })
    .catch(function(error) {
        alert('❌ Network error: ' + error.message);
    })
    .finally(function() {
        var btn = document.querySelector('#receiveStockPage .btn-gold');
        if (btn) {
            btn.innerHTML = '<i class="fas fa-arrow-down"></i> Receive Stock';
            btn.disabled = false;
        }
    });
}

function clearReceiveForm() {
    document.getElementById('receiveQty').value = '';
    document.getElementById('receiveBatch').value = '';
    document.getElementById('receiveExpiry').value = '';
    document.getElementById('receiveDNote').value = '';
    document.getElementById('receiveSupplier').value = '';
    document.getElementById('receiveRemarks').value = '';
    document.getElementById('receiveProduct').value = '';
    document.getElementById('receiveCurrentStock').textContent = '0';
    document.getElementById('receiveProductCode').textContent = '—';
    document.getElementById('receiveSearch').value = '';
    loadReceiveProducts();
}

// ============================================================
// INIT
// ============================================================
document.addEventListener('DOMContentLoaded', function() {
    console.log('💊 MedOx Pharmacy loaded');
    // Check if already logged in
    var token = localStorage.getItem('token');
    if (token) {
        console.log('Already logged in');
        // Load products for receive if on receive page
        var receivePage = document.getElementById('receiveStockPage');
        if (receivePage && receivePage.classList.contains('active')) {
            setTimeout(loadReceiveProducts, 500);
        }
    }
});
</script>
</body>
</html>
